default_platform(:ios)

platform :ios do
  desc "Build and upload to TestFlight"
  lane :deploy do
    api_key = app_store_connect_api_key(
      key_id: "9TKVU36G25",
      issuer_id: "947c7ee7-4c99-4b7a-96b7-227a9bf35ed5",
      key_filepath: "/Users/banghuazhao/Development/secret/AppStore Connect API keys/AuthKey_9TKVU36G25.p8",
      duration: 1200,
      in_house: false
    )

    # Ensure distribution certificate and provisioning profile are installed
    get_certificates(
      api_key: api_key,
      output_path: "/tmp/fastlane_certs"
    )
    get_provisioning_profile(
      api_key: api_key,
      app_identifier: "com.appsbay.classicMemoryGame",
      output_path: "/tmp/fastlane_profiles"
    )

    build_app(
      scheme: "Runner",
      workspace: "Runner.xcworkspace",
      export_method: "app-store",
      output_directory: "../build/ios/ipa",
      output_name: "classic_memory_game.ipa",
      clean: true
    )

    upload_to_testflight(
      api_key: api_key,
      skip_waiting_for_build_processing: true
    )
  end

  desc "Update What's New release notes on App Store Connect"
  lane :release_notes do
    api_key = app_store_connect_api_key(
      key_id: "9TKVU36G25",
      issuer_id: "947c7ee7-4c99-4b7a-96b7-227a9bf35ed5",
      key_filepath: "/Users/banghuazhao/Development/secret/AppStore Connect API keys/AuthKey_9TKVU36G25.p8",
      duration: 1200,
      in_house: false
    )

    deliver(
      api_key: api_key,
      app_identifier: "com.appsbay.classicMemoryGame",
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: false,
      metadata_path: File.join(__dir__, "metadata"),
      submit_for_review: false,
      automatic_release: false,
      precheck_include_in_app_purchases: false,
      force: true
    )
  end
end
